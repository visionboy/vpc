# ─────────────────────────────────────────────────────────────────────────
# Maven
# ─────────────────────────────────────────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ─────────────────────────────────────────────────────────────────────────
# IntelliJ IDEA
# ─────────────────────────────────────────────────────────────────────────
.idea/workspace.xml
.idea/tasks.xml
.idea/usage.statistics.xml
.idea/dictionaries/
.idea/shelf/
.idea/httpRequests/
.idea/dataSources/
.idea/dataSources.local.xml
.idea/*.iml
*.iws
*.iml
*.ipr
out/

# ─────────────────────────────────────────────────────────────────────────
# Claude Code 설정 파일 (로컬 전용)
# ─────────────────────────────────────────────────────────────────────────
CLAUDE.md

# ─────────────────────────────────────────────────────────────────────────
# Spring Boot / 민감 설정 파일 (절대 커밋 금지)
# ─────────────────────────────────────────────────────────────────────────
# 운영·로컬 전용 설정 — DB 자격증명, AWS 키 포함
src/main/resources/application-local.yml
src/main/resources/application-local.properties
src/main/resources/application-prod.yml
src/main/resources/application-prod.properties
src/main/resources/application-secret.yml
src/main/resources/application-secret.properties

# ─────────────────────────────────────────────────────────────────────────
# 환경 변수 파일
# ─────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─────────────────────────────────────────────────────────────────────────
# AWS 자격증명 (절대 커밋 금지)
# ─────────────────────────────────────────────────────────────────────────
.aws/
aws-credentials*
*credentials*.json
*credentials*.yml

# ─────────────────────────────────────────────────────────────────────────
# 로그 파일
# ─────────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ─────────────────────────────────────────────────────────────────────────
# OS 생성 파일
# ─────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────────────────────────────────
# 에디터 임시 파일
# ─────────────────────────────────────────────────────────────────────────
*.swp
*.swo
*~
.vscode/settings.json
.vscode/launch.json

# ─────────────────────────────────────────────────────────────────────────
# JVM / 테스트
# ─────────────────────────────────────────────────────────────────────────
hs_err_pid*
replay_pid*

# ─────────────────────────────────────────────────────────────────────────
# Terraform (절대 커밋 금지)
# ─────────────────────────────────────────────────────────────────────────
# 프로바이더 바이너리 및 플러그인 캐시 (수백 MB)
terraform/.terraform/
.terraform/
# 상태 파일 — 인프라 민감 정보 포함
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
*.tfstate
*.tfstate.*
# tfvars — 민감 변수값 포함 가능
*.tfvars
!*.tfvars.example
