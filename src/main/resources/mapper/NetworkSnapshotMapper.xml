<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.company.vpc.mapper.NetworkSnapshotMapper">

    <resultMap id="networkSnapshotMap" type="NetworkSnapshot">
        <id     property="id"               column="id"/>
        <result property="peeringHistoryId" column="peering_history_id"/>
        <result property="dataType"         column="data_type"/>
        <result property="snapshotData"     column="snapshot_data"/>
        <result property="createdAt"        column="created_at"/>
        <result property="updatedAt"        column="updated_at"/>
    </resultMap>

    <insert id="insert" parameterType="NetworkSnapshot"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO network_snapshot (
            peering_history_id, data_type, snapshot_data, created_at, updated_at
        ) VALUES (
            #{peeringHistoryId}, #{dataType}, #{snapshotData}, #{createdAt}, #{updatedAt}
        )
    </insert>

    <select id="findByPeeringHistoryId" resultMap="networkSnapshotMap">
        SELECT * FROM network_snapshot
        WHERE peering_history_id = #{peeringHistoryId}
        ORDER BY data_type
    </select>

</mapper>
